# ─── Database ─────────────────────────────────────────────────────────
# PostgreSQL connection string for Prisma.
# For Catalyst deployment, use your production database URL.
DATABASE_URL="postgresql://user:password@host:5432/crime_intel"

# ─── NextAuth (v4) ────────────────────────────────────────────────────
# Generate a strong random secret:  openssl rand -base64 32
AUTH_SECRET="change-this-to-a-random-secret"
NEXTAUTH_SECRET="change-this-to-a-random-secret"
# MUST match the public URL of the deployed app (no trailing slash)
AUTH_URL="https://your-app.catalystserverless.com"
NEXTAUTH_URL="https://your-app.catalystserverless.com"

# ─── ML Service (optional) ───────────────────────────────────────────
# URL of the Python ML micro-service.
ML_SERVICE_URL="http://localhost:8000"

# ─── Mapbox (optional) ────────────────────────────────────────────────
# Public token for geospatial map visualisations.
# Get one free at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=""