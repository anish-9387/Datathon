# ─── Database ──────────────────────────────────────────────────────────
# The ML service reads this but does NOT connect to the DB directly.
# Data is received via API requests from the Next.js app.
# Keep this for forward compatibility.
DATABASE_URL="postgresql://user:password@host:5432/crime_intel"

# ─── Model Cache ──────────────────────────────────────────────────────
# Directory to cache downloaded sentence-transformers models.
# In Docker, this is pre-downloaded at build time.
MODEL_CACHE_DIR="model_cache"

# ─── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL="INFO"

# ─── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Set to the deployed Next.js app URL in production.
CORS_ORIGINS="https://your-app.catalystserverless.com"

# ─── Embedding Model ──────────────────────────────────────────────────
# Sentence-transformers model name for FIR text embeddings.
EMBEDDING_MODEL="all-MiniLM-L6-v2"

# ─── Port (optional) ──────────────────────────────────────────────────
# Catalyst AppSail injects PORT or X_ZOHO_CATALYST_LISTEN_PORT automatically.
# Override here only for local testing.
# PORT=8000